    <timestamp key="STARTUP_TIME" datePattern="yyyy-MM-dd_HH-mm-ss" />

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>elt-${STARTUP_TIME}.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="debug">
        <appender-ref ref="FILE"/>
    </root>


</configuration>